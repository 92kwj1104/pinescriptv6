//@version=6
indicator("Mobile Signal Template v6", overlay = true, max_labels_count = 200)

// ─────────────────────────────────────────────────────────────
// Inputs
// ─────────────────────────────────────────────────────────────
fastLen = input.int(20, "Fast EMA", minval = 1)
slowLen = input.int(50, "Slow EMA", minval = 1)
rsiLen = input.int(14, "RSI Length", minval = 1)
rsiBull = input.float(52.0, "RSI Bull Threshold", minval = 1, maxval = 99)
rsiBear = input.float(48.0, "RSI Bear Threshold", minval = 1, maxval = 99)
showTable = input.bool(true, "Show Mobile Dashboard")
showSignals = input.bool(true, "Show BUY/SELL Labels")
confirmedOnly = input.bool(true, "Confirmed Bar Signals Only")

// ─────────────────────────────────────────────────────────────
// Calculations
// ─────────────────────────────────────────────────────────────
fast = ta.ema(close, fastLen)
slow = ta.ema(close, slowLen)
rsi = ta.rsi(close, rsiLen)
atr = ta.atr(14)

trendUp = fast > slow and close > slow
trendDown = fast < slow and close < slow
momentumUp = rsi >= rsiBull
momentumDown = rsi <= rsiBear

rawLong = ta.crossover(fast, slow) and momentumUp
rawShort = ta.crossunder(fast, slow) and momentumDown

longSignal = confirmedOnly ? rawLong and barstate.isconfirmed : rawLong
shortSignal = confirmedOnly ? rawShort and barstate.isconfirmed : rawShort

// ─────────────────────────────────────────────────────────────
// Visuals
// ─────────────────────────────────────────────────────────────
plot(fast, "Fast EMA", linewidth = 2)
plot(slow, "Slow EMA", linewidth = 2)

plotshape(showSignals and longSignal, title = "BUY", style = shape.labelup, location = location.belowbar, text = "BUY", size = size.small)
plotshape(showSignals and shortSignal, title = "SELL", style = shape.labeldown, location = location.abovebar, text = "SELL", size = size.small)

bgcolor(trendUp ? color.new(color.green, 92) : trendDown ? color.new(color.red, 92) : na)

// ─────────────────────────────────────────────────────────────
// Mobile dashboard
// ─────────────────────────────────────────────────────────────
var table dash = table.new(position.top_right, 2, 5)

signalText = longSignal ? "BUY" : shortSignal ? "SELL" : "WAIT"
trendText = trendUp ? "UP" : trendDown ? "DOWN" : "SIDE"
rsiText = str.tostring(rsi, "#.0")
atrText = str.tostring(atr, "#.00")

if showTable and barstate.islast
    table.cell(dash, 0, 0, "State")
    table.cell(dash, 1, 0, signalText)
    table.cell(dash, 0, 1, "Trend")
    table.cell(dash, 1, 1, trendText)
    table.cell(dash, 0, 2, "RSI")
    table.cell(dash, 1, 2, rsiText)
    table.cell(dash, 0, 3, "ATR")
    table.cell(dash, 1, 3, atrText)
    table.cell(dash, 0, 4, "TF")
    table.cell(dash, 1, 4, timeframe.period)

// ─────────────────────────────────────────────────────────────
// Alerts
// ─────────────────────────────────────────────────────────────
alertcondition(longSignal, "BUY Signal", "BUY signal on {{ticker}} {{interval}}")
alertcondition(shortSignal, "SELL Signal", "SELL signal on {{ticker}} {{interval}}")
